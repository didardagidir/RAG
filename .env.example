# LLM provider — Gemini's free tier needs no credit card (get a key at aistudio.google.com)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Other providers (uncomment one and set its key to switch — no other code changes):
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=

# Embedding model (HuggingFace id, runs locally via sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Where the vector store / data lives
VECTOR_STORE_DIR=./data
